<section class="cotownity {% if site == 'vanguard' %} vanguard {% else %} cotown {% endif %}" >
  {% if site == 'vanguard' %} 
    <div class="container-cotownity pure-g">
      <div class="pure-u-1">
        <div class="text-container">
          <h2 class="head2 title">{% literal texts, 'home-cotownity-titulo', L %}</h2>
        </div>
        <div class="widget">
          {% literal texts, 'home-cotownity-tag', L %}
        </div>
    </div>
  {% else %}
    <div class="container-cotownity cotown pure-g">
      <div class="container-img pure-u-1">
        <div class="left">
          <div class="redes-contain">
            <div class="insta-fb">
              <em class="icon-instagram"></em>
              <em class="icon-facebook"></em>
            </div>
          </div>          
          <div class="head2">{% literal texts, 'home-cotownity-titulo', L %}</div>
          <div class="head2 title-feel">{% literal texts, 'home-cotownity-hashtag', L %}</div>
        </div>
        {% image
          constants.SERVER + "/wopi/files/Marketing/Media/" + images['cotownity'].id +"/Image/contents?access_token=" + token,
          L, "community", "community", "community", "",
          [1280], ""
        %}       
      </div>

      <!-- Widget instagram -->
      <div class="container-widget">
        <div class="widget">
          {% literal texts, 'home-cotownity-tag', L %}
        </div>
      </div>
    </div>
  {% endif %}
</section>

<section class="cotownity-mobile">
  {% if site == 'vanguard' %}
    <div class="coral">
      <div class="head2">{% literal texts, 'home-cotownity-titulo', L %}</div>
    </div>
    {% literal texts, 'home-cotownity-tag-mobile', L %}
  {% else %}
    <div class="container-cotownity cotown pure-g">
      <div class="container-img pure-u-1">
        <div class="left">
          <div class="redes-contain">
            <div class="insta-fb">
              <em class="icon-instagram"></em>
              <em class="icon-facebook"></em>
            </div>
          </div>          
          <div class="head2">{% literal texts, 'home-cotownity-titulo', L %}</div>           
          <div class="head2 title-feel">{% literal texts, 'home-cotownity-hashtag', L %}</div>
        </div>
        {% image
          constants.SERVER + "/wopi/files/Marketing/Media/" + images['cotownity'].id +"/Image/contents?access_token=" + token,
          L, "community", "community", "community", "",
          [1280], ""
        %}       
      </div>     
    </div>
    {% literal texts, 'home-cotownity-tag-mobile', L %}
  {% endif %}
</section>

 