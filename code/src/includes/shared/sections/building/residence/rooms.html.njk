{% set show = true %}
{% for r in rooms | find('id', 'eq', building.id) %}
{% for p in r.Place_types %}
{% if p.Code[0] == type %}
{% if f.Rent_pct %}{% set pct = f.Rent_pct %}{% else %}{% set pct = 1.0 %}{% endif %}

{% if show %}
{% set show = false %}
<div class="title pure-u-1 pure-u-lg-21-24">
  <h2 class="head2">{{typetitle}}</h2>
  <!-- PROMO -->
  {% set rent_pct = 0.0 %}
  {% set fee_pct = 0.0 %}
  {% for x in promos %}
    {% if x.building == building.id and (not x.flat_type or x.flat_type | slice(0, 3) != 'APT') and (not x.place_type or x.place_type | slice(0, 1) != p.Code[0]) %}
      {% if x.Value_rent_pct | float < rent_pct  %}
        {% set rent_pct = x.Value_rent_pct | float %}
      {% endif %}
      {% if x.Value_fee_pct | float < fee_pct %}
        {% set fee_pct = x.Value_fee_pct | float %}
      {% endif %}
    {% endif %}
  {% endfor %}
  {% if rent_pct < 0 %}
  <div class="sticker sticker-primary">
    <span class="line1">{% literal texts, 'promo-upto', L %} {{rent_pct|round(1)}}% {% literal texts, 'promo-discount', L %}</span>
    <span class="line2">{% literal texts, 'promo-rent', L %}</span>
  </div>
  {% endif %}
  {% if fee_pct < 0 %}
  <div class="sticker sticker-secondary">
    <span class="line1">{% literal texts, 'promo-upto', L %} {{fee_pct|round(1)}}% {% literal texts, 'promo-discount', L %}</span>
    <span class="line2">{% literal texts, 'promo-fee', L %}</span>
  </div>
  {% endif %}
</div>
{% endif %}

<!-- Big photos -->
<section id="big-{{p.Code}}" class="splide hidden-div">
  <div class="photos">
    <div class="close" onclick="document.getElementById('big-{{p.Code}}').style.display = 'none';"><em class="icon-close"></em></div>
    <div class="splide__track">
      <ul class="splide__list">
        {% for rp in photos | find('Building.id', 'eq', building.id) | find('Place_type.Code', 'eq', p.Code) %}
        <li class="splide__slide">
        <div class="bigdiv">
        {% image
          constants.SERVER + "/wopi/files/Marketing/Media_resource_type/" + rp.id +"/Image/contents?access_token=" + token,
          L, rp.Name, rp.Name, building.Code + '-' + p.Code + '-' + rp.id, "bigimage",
          [1280], ""
        %}
        </div>
        </li>
      {% endfor %}
      </ul>
    </div>
  </div>
</section>

<anchor class="anchor" id="{{type}}"></anchor> 
<section class="card-room pure-u-1 pure-u-lg-22-24">

  <!-- LEFT -->
  <div class="left-carousel pure-u-1 pure-u-lg-11-24">

    <section id="main-carousel-{{p.Code}}" class="splide rooms-carousel" aria-label="Gallery">
      <div class="splide__track" onclick="document.getElementById('big-{{p.Code}}').style.display = 'flex';">
        <ul class="splide__list">
          {% for rp in photos | find('Building.id', 'eq', building.id) | find('Place_type.Code', 'eq', p.Code) %}
          <li class="splide__slide">
            {% image
              constants.SERVER + "/wopi/files/Marketing/Media_resource_type/" + rp.id +"/Image/contents?access_token=" + token,
              L, rp.Name, rp.Name, building.Code + '-' + p.Code + '-' + rp.id, "",
              [1280], ""
            %}
          </li>
          {% endfor %}
        </ul>
      </div>
    </section>

    <section id="thumbnail-carousel-{{p.Code}}" class="splide" aria-label="Thumbnails">
      <div class="splide__track">
        <ul class="splide__list">
          {% for rp in photos | find('Building.id', 'eq', building.id) | find('Place_type.Code', 'eq', p.Code) %}
          <li class="splide__slide">
            {% image
              constants.SERVER + "/wopi/files/Marketing/Media_resource_type/" + rp.id +"/Image/contents?access_token=" + token,
              L, rp.Name, rp.Name, building.Code + '-' + p.Code + '-' + rp.id, "",
              [1280], ""
            %}
          </li>
          {% endfor %}
        </ul>
      </div>
    </section>

    {% literal texts, 'photo-note', L, true %}

  </div>

  <!-- RIGHT -->
  <div class="right-data pure-u-11-12 pure-u-lg-11-24">

    <!-- Title -->
    <div class="title-favorite pure-u-1">
      <h3>{{place_types[p.Code] | translate('Name', L)}}</h3>
      <!--
      <em class="icon-heart"></em>
      -->
    </div>

    <!-- Description -->
    <div class="text pure-u-1">
    {% set matches = place_types[p.Code].Texts | find('Building_id', 'eq', building.id) %}
    {% if matches | length > 0 %}{% set building_text = matches | first %}{% else %}{% set building_text = None %}{% endif %}
    {% set matches = place_types[p.Code].Texts | find ('Location_id', 'eq', building.District.Location.id) %}
    {% if matches | length > 0 %}{% set location_text = matches | first %}{% else %}{% set location_text = None %}{% endif %}
    {% set matches = place_types[p.Code].Texts | find ('Building_id', 'eq', null) | find ('Location_id', 'eq', null) %}
    {% if matches | length > 0 %}{% set default_text = matches | first %}{% else %}{% set default_text = None %}{% endif %}
    {{ (building_text or location_text or default_text) | translate('Description', L) | markdown | safe }}
    </div>

    <form class="pure-form">
      <fieldset>

      <!-- Share -->
      <div class="share">
        {% for f in p.Flat_types %}
        <div class="sharing">
          <div class="left">
            <label id="label-{{p.Code}}_{{f.Code}}" for="radio-{{p.Code}}_{{f.Code}}" class="pure-radio">
            <input id="radio-{{p.Code}}_{{f.Code}}"{% if p.Flat_types | length == 1 %} checked{% endif %}
                   class="hidden"
                   name="radio-{{p.Code}}" 
                   data-flat="{{f.id}}" type="radio"/>
            </label>
          </div>
          <div class="right">
            {% if f.Rent_pct %}{% set pct = f.Rent_pct %}{% else %}{% set pct = 1.0 %}{% endif %}
            {% if pct != 1 %}
            <p data-price="f"  class="right linethru hidden">{% literal texts, 'price-desde', L %} {{f.Rent_long       |round|number(L)}} €/{% literal texts, 'price-mes', L %}</p>
            <p data-price="l"  class="right linethru hidden" id="l_{{p.Code}}_{{f.Code}}">         {{f.Rent_long       |round|number(L)}} €/{% literal texts, 'price-mes', L %}</p>
            <p data-price="m"  class="right linethru hidden" id="m_{{p.Code}}_{{f.Code}}">         {{f.Rent_medium     |round|number(L)}} €/{% literal texts, 'price-mes', L %}</p>
            <p data-price="s"  class="right linethru hidden" id="s_{{p.Code}}_{{f.Code}}">         {{f.Rent_short      |round|number(L)}} €/{% literal texts, 'price-mes', L %}</p>
            <p data-price="ln" class="right linethru hidden" id="l_{{p.Code}}_{{f.Code}}">         {{f.Rent_long_next  |round|number(L)}} €/{% literal texts, 'price-mes', L %}</p>
            <p data-price="mn" class="right linethru hidden" id="m_{{p.Code}}_{{f.Code}}">         {{f.Rent_medium_next|round|number(L)}} €/{% literal texts, 'price-mes', L %}</p>
            <p data-price="sn" class="right linethru hidden" id="s_{{p.Code}}_{{f.Code}}">         {{f.Rent_short_next |round|number(L)}} €/{% literal texts, 'price-mes', L %}</p>
            <p data-price="f"  class="red right hidden">                             {% literal texts, 'price-desde', L %} {{(f.Rent_long       *pct)|round|number(L)}} €/{% literal texts, 'price-mes', L %}</p>
            <p data-price="l"  class="red right hidden" id="l_{{p.Code}}_{{f.Code}}">{% literal texts, 'price-desde', L %} {{(f.Rent_long       *pct)|round|number(L)}} €/{% literal texts, 'price-mes', L %}</p>
            <p data-price="m"  class="red right hidden" id="m_{{p.Code}}_{{f.Code}}">{% literal texts, 'price-desde', L %} {{(f.Rent_medium     *pct)|round|number(L)}} €/{% literal texts, 'price-mes', L %}</p>
            <p data-price="s"  class="red right hidden" id="s_{{p.Code}}_{{f.Code}}">{% literal texts, 'price-desde', L %} {{(f.Rent_short      *pct)|round|number(L)}} €/{% literal texts, 'price-mes', L %}</p>
            <p data-price="ln" class="red right hidden" id="l_{{p.Code}}_{{f.Code}}">{% literal texts, 'price-desde', L %} {{(f.Rent_long_next  *pct)|round|number(L)}} €/{% literal texts, 'price-mes', L %}</p>
            <p data-price="mn" class="red right hidden" id="m_{{p.Code}}_{{f.Code}}">{% literal texts, 'price-desde', L %} {{(f.Rent_medium_next*pct)|round|number(L)}} €/{% literal texts, 'price-mes', L %}</p>
            <p data-price="sn" class="red right hidden" id="s_{{p.Code}}_{{f.Code}}">{% literal texts, 'price-desde', L %} {{(f.Rent_short_next *pct)|round|number(L)}} €/{% literal texts, 'price-mes', L %}</p>
            {% else %}
            <p data-price="f"  class="right">{% literal texts, 'price-desde', L %} {{f.Rent_long       |round|number(L)}} €/{% literal texts, 'price-mes', L %}</p>
            <p data-price="l"  class="right hidden" id="l_{{p.Code}}_{{f.Code}}"> {{f.Rent_long       |round|number(L)}} €/{% literal texts, 'price-mes', L %}</p>
            <p data-price="m"  class="right hidden" id="m_{{p.Code}}_{{f.Code}}"> {{f.Rent_medium     |round|number(L)}} €/{% literal texts, 'price-mes', L %}</p>
            <p data-price="s"  class="right hidden" id="s_{{p.Code}}_{{f.Code}}"> {{f.Rent_short      |round|number(L)}} €/{% literal texts, 'price-mes', L %}</p>
            <p data-price="ln" class="right hidden" id="l_{{p.Code}}_{{f.Code}}"> {{f.Rent_long_next  |round|number(L)}} €/{% literal texts, 'price-mes', L %}</p>
            <p data-price="mn" class="right hidden" id="m_{{p.Code}}_{{f.Code}}"> {{f.Rent_medium_next|round|number(L)}} €/{% literal texts, 'price-mes', L %}</p>
            <p data-price="sn" class="right hidden" id="s_{{p.Code}}_{{f.Code}}"> {{f.Rent_short_next |round|number(L)}} €/{% literal texts, 'price-mes', L %}</p>
            {% endif %}
          </div>
        </div>
        <div id="{{p.Code}}_{{f.Code}}" data-id="{{p.Code}}" class="text-red"><p>...</p></div>
        {% endfor %}
      </div>

      </fieldset>
    </form>

    <div class="buttons pure-u-1">
      <button id="btn-check-{{p.Code}}" name="btn-check" class="invisible btn-secondary" onclick="go_check();">
        {% literal texts, 'button-solicitar', L %}
      </button>
      <button id="btn-book-{{p.Code}}" name="btn-book" class="invisible btn-secondary" onclick="go_book({{p.id}}, -1, '{{p.Code}}', 'rs');">
        {% literal texts, 'button-reservar', L %}
      </button>
      <button id="btn-info-{{p.Code}}" name="btn-info" class="btn-primary" onclick="go_info({{p.id}}, -1, '{{p.Code}}');">
        {% literal texts, 'button-mas-info', L %}
      </button>
      <button id="btn-visit-{{p.Code}}" name="btn-visit" class="btn-primary" onclick="go_visit({{p.id}}, -1, '{{p.Code}}');">
        {% literal texts, 'button-visita', L %}
      </button>
    </div>

  </div>

  <!-- Expansion -->
  <!--
  <div class="description text pure-u-23-24">
      <div class="expansion pure-u-1">
        <p>{% literal texts, 'informacion-adicional-titulo', L %}</p>
        <input type="checkbox" class="tab pure-u-1-2" id="tab1" tabindex="0"/>
        <label name="tab" for="tab1" tabindex="-1" class="tab_lab pure-u-1-2" role="tab">
          <span class="open-close-icon"><em class="icon-corchete-down"></em></span>
        </label>
        <div class="content pure-u-1">
          <p>{% literal texts, 'informacion-adicional-texto', L %}</p>
        </div>
      </div>
  </div>
  -->

</section>
{% endif %}
{% endfor %}
{% endfor %}